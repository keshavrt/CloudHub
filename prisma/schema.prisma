// Prisma schema for Event & Media Management Platform

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PHOTOGRAPHER
  CLUB_MEMBER
  VIEWER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(VIEWER)
  clubName      String?        // Applicable if part of a club
  avatarUrl     String?
  selfieUrl     String?        // Reference selfie for facial recognition
  selfieVector  Float[]        // 128-dimensional face descriptor for reference selfie
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Relations
  uploadedMedia Media[]        @relation("UploadedMedia")
  likes         Like[]
  comments      Comment[]
  favorites     Favorite[]
  taggedIn      FaceTag[]      @relation("UserFaceTags")
  notifications Notification[]
}

model Event {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   // e.g. workshop, party, fest, competition
  date        DateTime
  location    String?  // Venue or city
  isPrivate   Boolean  @default(false)
  clubName    String?  // Which club organizes it
  coverImage  String?  // Cover image URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  albums      Album[]
  media       Media[]
}

model Album {
  id          String   @id @default(uuid())
  name        String
  description String?
  eventId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  media       Media[]
}

model Media {
  id          String   @id @default(uuid())
  url         String   // Cloud storage URL
  fileName    String
  fileType    String   // "image" or "video"
  fileSize    Int
  width       Int?
  height      Int?
  eventId     String
  albumId     String?
  uploaderId  String
  caption     String?  // AI generated or custom
  isPrivate   Boolean  @default(false)
  tags        String[] // AI generated semantic tags (e.g. ["sports", "mountains"])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  album       Album?    @relation(fields: [albumId], references: [id], onDelete: SetNull)
  uploader    User      @relation("UploadedMedia", fields: [uploaderId], references: [id])
  likes       Like[]
  comments    Comment[]
  favorites   Favorite[]
  faceTags    FaceTag[]
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
}

model FaceTag {
  id             String   @id @default(uuid())
  mediaId        String
  userId         String?  // If matched to a registered user
  name           String?  // Guest or manually tagged name
  descriptor     Float[]  // 128-dimensional face embedding array
  boundingBox    Json     // Coordinates { x: number, y: number, width: number, height: number }
  createdAt      DateTime @default(now())

  // Relations
  media          Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user           User?    @relation("UserFaceTags", fields: [userId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // Receiver of notification
  type      String   // "like", "comment", "tag"
  message   String
  isRead    Boolean  @default(false)
  mediaId   String?
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
